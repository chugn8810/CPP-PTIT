#include <iostream>
#include <algorithm>
#include <vector>
#include <map>
#include <set>
using namespace std;
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        int n;
        cin >> n;
        vector<int> a(n), b(n);
        for (int i = 0; i < n; i++)
        {
            cin >> a[i];
            b[i] = a[i];
        }
        sort(a.begin(), a.end());
        for (int i = 0; i < n; i++)
        {
            auto it = upper_bound(a.begin(), a.end(), b[i]);
            if (it == a.end())
                cout << "_" << " ";
            else
                cout << *it << " ";
        }
        cout << endl;
    }
}
