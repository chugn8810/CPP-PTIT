using namespace std;
const int MAXN = 1000005;
int vitri[MAXN] = {0};
void sang()
{
    for (int i = 1; i < MAXN; i++)
    {
        for (int j = i; j < MAXN; j += i)
        {
            vitri[j]++;
        }
    }
}
int main()
{
    sang();
