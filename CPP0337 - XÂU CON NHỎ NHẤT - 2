#include <iostream>
#include <string>
#include <map>
#include <vector>
#include <cstring>
using namespace std;
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        map<char, int> mp, ms;
        string s;
        cin >> s;
        for (int i = 0; i < s.size(); i++)
        {
            mp[s[i]]++;
        }
        int left = 0, dem = 0, min = 1e9;
        for (int i = 0; i < s.size(); i++)
        {
            ms[s[i]]++;
            if (ms[s[i]] == 1)
            {
                ++dem;
            }
            if (dem == mp.size())
            {
                while (dem == mp.size())
                {
                    int so = i - left + 1;
                    if (so < min)
                        min = so;
                    if (ms[s[left]] - 1 != 0)
                    {
                        ms[s[left]]--;
                    }
                    else
                    {
                        break;
                    }
                    ++left;
                }
            }
        }
        cout << min << endl;
    }
}
